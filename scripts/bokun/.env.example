# Copy to scripts/bokun/.env and fill in.
# Never commit the real .env — it's in .gitignore.
#
# Get these from Bokun extranet → Settings → API keys.

BOKUN_ACCESS_KEY=
BOKUN_SECRET_KEY=

# Optional. Defaults to https://api.bokun.io.
# Override only if Bokun gave you a dedicated host.
# BOKUN_API_HOST=https://api.bokun.io
