# Copy this file to scripts/supabase/.env (gitignored) and fill in the
# values from the Supabase dashboard:
#
#   1. https://supabase.com/dashboard/projects → open the horizon-database project
#   2. Sidebar → Settings (gear icon) → API
#       • Project URL                 → SUPABASE_URL
#       • Project API keys → service_role → SUPABASE_SERVICE_KEY
#
# The service_role key bypasses Row-Level Security. Treat it like a
# database password: paste it once here, save a copy to your password
# manager, and never commit it or put it in any frontend bundle.

SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
SUPABASE_SERVICE_KEY=PASTE_SERVICE_ROLE_KEY_HERE
